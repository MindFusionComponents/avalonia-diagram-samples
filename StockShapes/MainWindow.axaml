<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
		xmlns:diag="using:MindFusion.Diagramming.Avalonia"
        mc:Ignorable="d" d:DesignWidth="1024" d:DesignHeight="768"
        Width="1024" Height="768"
        x:Class="StockShapes.MainWindow"
        Title="MindFusion.Diagramming Sample: Predefined Shapes">

	<Grid RowDefinitions="*, Auto">
		<diag:DiagramView x:Name="diagramView" Grid.Row="0" />

		<!-- Bottom: Description TextBlock -->
		<Border Grid.Row="1" BorderThickness="1" BorderBrush="LightGray" Padding="10" Margin="10">
			<TextBlock TextWrapping="Wrap">
				This sample demonstrates the predefined MindFusion.Diagramming shape geometries and their unique identifiers, helping you select the appropriate shapes for your diagrams.
			</TextBlock>
		</Border>
	</Grid>

</Window>