<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
		xmlns:diag="using:MindFusion.Diagramming.Avalonia"
        mc:Ignorable="d" d:DesignWidth="900" d:DesignHeight="600"
        Width="900" Height="600"
        x:Class="StressTest.MainWindow"
        Title="MindFusion.Diagramming Sample: Stress Test">

	<Grid RowDefinitions="*, Auto">
		<diag:DiagramView x:Name="diagramView" Grid.Row="0" />
	
		<Grid Grid.Row="1" ColumnDefinitions="Auto, *">
			<Button Content="Create items" Click="OnCreateItems" Padding="10" />
			<Border BorderThickness="1" BorderBrush="LightGray" Grid.Column="1">
				<TextBlock Padding="10" TextWrapping="Wrap">
					Click the button to create 20000 nodes and links in total. Diagram's spatial indexing allows for fast hit-test and viewport queries during rendering and user interactions.
				</TextBlock>
			</Border>
		</Grid>
	</Grid>

</Window>