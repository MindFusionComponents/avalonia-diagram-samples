<Application xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:local="using:CloudDesigner"
             xmlns:diag="using:MindFusion.Diagramming.Avalonia"
             x:Class="CloudDesigner.App"
             RequestedThemeVariant="Default">

    <Application.Styles>
        <FluentTheme />
        
        <!-- Style for all DiagramLinks -->
        <Style Selector="diag|DiagramLink">
            <Setter Property="Stroke" Value="#A9A9A9" />
            <Setter Property="StrokeThickness" Value="1.5" />
            <Setter Property="HeadShapeSize" Value="3" />
        </Style>

        <Style Selector="local|CloudNode">
            <Setter Property="Template">
                <DataTemplate DataType="local:CloudNode">
                    <Grid Width="{Binding Bounds.Width}" Height="{Binding Bounds.Height}" MinWidth="180" MinHeight="80">
                        <Border CornerRadius="8" Background="White" BoxShadow="0 2 10 0 #20000000">
                             <Grid Margin="10">
                                <Grid ColumnDefinitions="Auto, *">
                                    <Viewbox Width="40" Height="40" VerticalAlignment="Top">
                                        <Image Source="{Binding Icon}" Stretch="Uniform" />
                                    </Viewbox>
                                    <StackPanel Grid.Column="1" Margin="10,0,0,0" VerticalAlignment="Center">
                                        <TextBlock Text="{Binding Title}" FontWeight="Bold" FontSize="14" />
                                        <TextBlock Text="{Binding Description}" FontSize="11" Foreground="Gray" TextWrapping="Wrap" />
                                    </StackPanel>
                                </Grid>
                                <Ellipse Width="10" Height="10" 
                                         Fill="{Binding StatusBrush}" 
                                         HorizontalAlignment="Right" 
                                         VerticalAlignment="Bottom" />
                            </Grid>
                        </Border>
                    </Grid>
                </DataTemplate>
            </Setter>
        </Style>
    </Application.Styles>
</Application>