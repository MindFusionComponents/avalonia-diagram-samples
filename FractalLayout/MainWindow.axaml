<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
		xmlns:diag="using:MindFusion.Diagramming.Avalonia"
        mc:Ignorable="d" d:DesignWidth="1024" d:DesignHeight="768"
        Width="800" Height="600"
        x:Class="FractalLayout.MainWindow"
        Title="MindFusion.Diagramming Sample: Fractal Layout">

	<Grid RowDefinitions="*, Auto">
		<diag:DiagramView
			x:Name="diagramView"
			Grid.Row="0"
			Behavior="Pan"
			LightweightPresenters="True"
			PointerWheelChanged="OnPointerWheelChanged" />

		<Grid Grid.Row="1" ColumnDefinitions="Auto, *" Margin="10">
			<Button Content="Random tree"
					Click="button_Click"
					Width="120" Height="60"
					HorizontalContentAlignment="Center"
					VerticalContentAlignment="Center"
					Margin="0,0,10,0" />

			<Border Grid.Column="1" BorderThickness="1" BorderBrush="LightGray" Padding="10">
				<TextBlock TextWrapping="Wrap" VerticalAlignment="Center">
					This example demonstrates the FractalLayout tree layout algorithm. Click the button to generate a random tree and arrange it.
				</TextBlock>
			</Border>
		</Grid>
	</Grid>

</Window>